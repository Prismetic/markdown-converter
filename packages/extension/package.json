{
  "name": "@tool/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.sw.json --noEmit",
    "size-check": "bash ../../scripts/check-size.sh _dist"
  },
  "dependencies": {
    "@tool/core": "*"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/chrome": "^0.2.0",
    "happy-dom": "^20.10.6",
    "terser": "^5.48.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.19",
    "vite-plugin-web-extension": "^4.5.1",
    "vitest": "^2.1.9"
  }
}
